# EmailJS — powers the booking form on /contact
# Setup: https://www.emailjs.com/docs/
# 1. Sign up free at emailjs.com
# 2. Add a Service (Gmail / Outlook / SMTP)
# 3. Create a Template using these variables:
#    {{from_name}}, {{reply_to}}, {{company}}, {{services}}, {{budget}}, {{message}}
# 4. Copy your IDs below and rename this file to .env.local
#
# These are NEXT_PUBLIC_* because EmailJS runs in the browser.
# If left unset, the form falls back to opening the visitor's mail client.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
